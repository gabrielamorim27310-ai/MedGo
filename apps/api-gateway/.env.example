PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://acolhe:acolhe@localhost:5433/acolhe?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# CORS
# Lista separada por virgula (localhost + dominio de producao)
CORS_ORIGIN=http://localhost:3000,https://seu-dominio.vercel.app

# Services URLs (for microservices architecture)
QUEUE_SERVICE_URL=http://localhost:3002
NOTIFICATION_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
INTEGRATION_SERVICE_URL=http://localhost:3005

# SSO Google (Google Identity Services)
# Aceita varios client IDs separados por virgula (ex.: um do localhost e
# outro do dominio de producao/Vercel)
GOOGLE_CLIENT_ID=seu-client-id-local.apps.googleusercontent.com,seu-client-id-producao.apps.googleusercontent.com

# Verificacao de e-mail e reset de senha (Resend - https://resend.com)
# Sem a chave, os links sao logados no console (modo dev)
RESEND_API_KEY=
EMAIL_FROM="Acolhe <onboarding@resend.dev>"

# URL do frontend usada nos links de e-mail
FRONTEND_URL=http://localhost:3000
